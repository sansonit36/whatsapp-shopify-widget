<%
var activePage = 'billing';
var pageTitle = 'Billing';
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> — WhatsApp Widget Admin</title>
  <link rel="stylesheet" href="/admin.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="app-layout">
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span>WA Widget</span>
        </div>
      </div>
      <nav class="sidebar-nav">
        <a href="/admin/dashboard?shop=<%= shop.shopDomain %>" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Dashboard
        </a>
        <a href="/admin/settings?shop=<%= shop.shopDomain %>" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Settings
        </a>
        <a href="/admin/billing?shop=<%= shop.shopDomain %>" class="nav-item active">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          Billing
        </a>
      </nav>
      <div class="sidebar-footer">
        <div class="plan-badge plan-<%= shop.plan %>"><%= shop.plan.charAt(0).toUpperCase() + shop.plan.slice(1) %> Plan</div>
        <div class="shop-domain"><%= shop.shopDomain %></div>
      </div>
    </aside>

    <main class="main-content">
      <div class="page-header">
        <div>
          <h1>Plans & Billing</h1>
          <p class="subtitle">Choose the plan that fits your business</p>
        </div>
      </div>

      <% if (reason === 'limit') { %>
      <div class="alert alert-warning">⚠ You've reached your placement limit. Upgrade to add more.</div>
      <% } %>
      <% if (reason === 'type') { %>
      <div class="alert alert-warning">⚠ This placement type isn't available on your current plan. Upgrade to unlock it.</div>
      <% } %>

      <div class="pricing-grid">
        <!-- Free Plan -->
        <div class="pricing-card <%= shop.plan === 'free' ? 'current' : '' %>">
          <div class="plan-name">Free</div>
          <div class="plan-price">$0<span>/mo</span></div>
          <ul class="plan-features">
            <li>1 floating bubble placement</li>
            <li>Basic widget customization</li>
            <li>"Powered by" badge</li>
          </ul>
          <% if (shop.plan === 'free') { %>
          <div class="current-badge">Current Plan</div>
          <% } %>
        </div>

        <!-- Basic Plan -->
        <div class="pricing-card popular <%= shop.plan === 'basic' ? 'current' : '' %>">
          <div class="popular-badge">Most Popular</div>
          <div class="plan-name">Basic</div>
          <div class="plan-price">$2.99<span>/mo</span></div>
          <ul class="plan-features">
            <li>Up to 3 placements</li>
            <li>All placement types</li>
            <li>7-day click analytics</li>
            <li>Business hours scheduling</li>
            <li>No "Powered by" badge</li>
          </ul>
          <% if (shop.plan === 'basic') { %>
          <div class="current-badge">Current Plan</div>
          <% } else { %>
          <form method="POST" action="/admin/billing/subscribe?shop=<%= shop.shopDomain %>">
            <input type="hidden" name="plan" value="basic">
            <button type="submit" class="btn btn-primary btn-block">Start 7-Day Trial</button>
          </form>
          <% } %>
        </div>

        <!-- Pro Plan -->
        <div class="pricing-card <%= shop.plan === 'pro' ? 'current' : '' %>">
          <div class="plan-name">Pro</div>
          <div class="plan-price">$7.99<span>/mo</span></div>
          <ul class="plan-features">
            <li>Unlimited placements</li>
            <li>90-day analytics with charts</li>
            <li>Multiple WhatsApp numbers</li>
            <li>GDPR consent mode</li>
            <li>Priority support</li>
            <li>No badge</li>
          </ul>
          <% if (shop.plan === 'pro') { %>
          <div class="current-badge">Current Plan</div>
          <% } else { %>
          <form method="POST" action="/admin/billing/subscribe?shop=<%= shop.shopDomain %>">
            <input type="hidden" name="plan" value="pro">
            <button type="submit" class="btn btn-primary btn-block">Start 7-Day Trial</button>
          </form>
          <% } %>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
